# =========================================================
# Codex Gateway - 环境变量配置模板
# =========================================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 修改下面的配置值
# 3. ⚠️ 切勿将 .env 文件提交到 Git！
# =========================================================

# VLLM 服务地址（必填）
# 格式：http://<服务器IP>:<端口>/v1
VLLM_BASE_URL="http://your-server:port/v1"

# 模型名称（可选，默认：Qwen/Qwen3.5-397B-A17B-FP8）
MODEL_NAME="Qwen/Qwen3.5-397B-A17B-FP8"

# =========================================================
# 其他可选配置（参考 config.py）
# =========================================================
# CODEX_API_BASE="http://your-server:port/v1"
# CODEX_MODEL="Qwen/Qwen3.5-397B-A17B-FP8"
# CODEX_API_KEY="your-api-key"
# CODEX_TEMPERATURE="0.6"
# CODEX_MAX_TURNS="50"
# CODEX_AUTO_APPROVE="false"
# CODEX_WORKSPACE="/path/to/your/workspace"
