# =========================================================
# Codex CLI - 环境变量配置模板
# =========================================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 修改下面的配置值
# 3. ⚠️ 切勿将 .env 文件提交到 Git！
# =========================================================

# ---------------------------------------------------------
# Codex CLI 配置
# ---------------------------------------------------------
# API 基地址（CLI 使用）
CODEX_API_BASE="http://127.0.0.1:8080/v1"

# 模型名称
CODEX_MODEL="Qwen/Qwen3.5-397B-A17B-FP8"

# API 密钥（如果使用认证）
CODEX_API_KEY="dummy"

# 采样温度（0.0 - 2.0）
# 建议：代码任务 0.15~0.25，讨论/设计 0.6~0.8
CODEX_TEMPERATURE="0.2"

# 最大工具调用轮次
CODEX_MAX_TURNS="50"

# 是否自动审批文件修改（true/false）
CODEX_AUTO_APPROVE="false"

# 默认工作目录
# CODEX_WORKSPACE="/path/to/your/workspace"

# ---------------------------------------------------------
# Gateway 配置（仅在使用 API 网关时需要）
# ---------------------------------------------------------
# vLLM 服务地址
VLLM_BASE_URL="http://your-server:7980"

# 模型名称（Gateway 使用）
MODEL_NAME="Qwen/Qwen3.5-397B-A17B-FP8"

# Metrics 刷新间隔（秒）
POLL_INTERVAL="5"

# ---------------------------------------------------------
# 计费配置（可选）
# ---------------------------------------------------------
# 输入价格（每 1M tokens，人民币）
INPUT_PRICE_PER_1M="3.0"

# 输出价格（每 1M tokens，人民币）
OUTPUT_PRICE_PER_1M="6.0"

# 缓存命中价格（每 1M tokens，人民币）
CACHED_INPUT_PRICE_PER_1M="0.025"

# TTFT 缓存命中阈值（秒）
TTFT_CACHE_HIT_THRESHOLD="0.5"
